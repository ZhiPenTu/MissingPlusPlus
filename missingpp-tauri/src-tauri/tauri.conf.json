{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Missing++",
  "version": "0.1.0",
  "identifier": "com.tuzhipeng.MissingPlusPlus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Missing++",
        "width": 480,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": [
      "icons/MenuBarIcon.png",
      "icons/MenuBarIcon-happy.png",
      "icons/MenuBarIcon-joyful.png",
      "icons/MenuBarIcon-delighted.png",
      "icons/MenuBarIcon-sad.png",
      "icons/MenuBarIcon-longing.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "category": "Productivity",
    "shortDescription": "焦虑型依恋人格的记录 + 自我安抚菜单栏 app",
    "longDescription": "Missing++ 是面向焦虑型依恋人格的 macOS 菜单栏 app：记录想念的浪、累积平复证据、3 个 DBT sub-sheet 在浪来时接住你。"
  }
}
