{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Missing++",
  "version": "0.1.0",
  "identifier": "com.tuzhipeng.MissingPlusPlus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Missing++",
        "width": 480,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/MenuBarIcon.png",
      "icons/MenuBarIcon-happy.png",
      "icons/MenuBarIcon-joyful.png",
      "icons/MenuBarIcon-delighted.png",
      "icons/MenuBarIcon-sad.png",
      "icons/MenuBarIcon-longing.png"
    ]
  }
}
